# Public site configuration
PUBLIC_SITE_URL=https://example.com
PUBLIC_GTM_CONTAINER_ID=
PUBLIC_GOOGLE_SITE_VERIFICATION=

# Dynamic content source: markdown | microcms
CONTENT_SOURCE=markdown
CONTENT_FALLBACK_TO_MARKDOWN=true

# microCMS Content API (server-only except the service domain)
MICROCMS_SERVICE_DOMAIN=
MICROCMS_API_KEY=

# microCMS Management API (server-only; optional when MICROCMS_API_KEY has API-info permission)
MICROCMS_MANAGEMENT_API_KEY=
