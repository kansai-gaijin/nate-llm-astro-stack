{
  "name": "nate-llm-astro-stack",
  "type": "module",
  "version": "0.1.0",
  "description": "Interactive Astro design-loop starter for Codex and Claude Code.",
  "license": "MIT",
  "bin": {
    "nate-llm-astro-stack": "./bin/nate-llm-astro-stack.mjs"
  },
  "files": [
    ".agents",
    ".claude",
    ".codex",
    ".github",
    "bin",
    "content",
    "deployment",
    "media",
    "microcms",
    "public",
    "scaffold",
    "scripts",
    "src",
    "tests",
    "workflow",
    ".env.example",
    "AGENTS.md",
    "CLAUDE.md",
    "astro.config.mjs",
    "playwright.config.ts",
    "README.md",
    "tsconfig.json"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "content:validate": "node scripts/validate-content.mjs",
    "reference:validate": "node scripts/validate-reference.mjs",
    "artifacts:validate": "node scripts/validate-artifacts.mjs",
    "media:validate": "node scripts/validate-media.mjs",
    "dynamic:validate": "node scripts/validate-dynamic-content.mjs",
    "microcms:check": "node scripts/microcms-check.mjs",
    "qa:capture:reference": "node scripts/capture-site.mjs --target reference",
    "qa:capture:implementation": "node scripts/capture-site.mjs --target implementation",
    "qa:diff": "node scripts/visual-diff.mjs",
    "test:e2e": "npm run build && playwright test",
    "test": "npm run content:validate && npm run reference:validate && npm run artifacts:validate && npm run media:validate && npm run dynamic:validate && npm run check && npm run test:e2e",
    "loop:status": "node scripts/loop-state.mjs status",
    "loop:serve:start": "node scripts/dev-server.mjs start",
    "loop:serve:status": "node scripts/dev-server.mjs status",
    "loop:serve:stop": "node scripts/dev-server.mjs stop",
    "deploy:cloudflare": "npm run build && wrangler pages deploy dist",
    "create:test": "node scripts/test-create.mjs",
    "prepack": "npm run check && npm run create:test"
  },
  "dependencies": {
    "@astrojs/alpinejs": "^0.5.0",
    "@iconify-json/mdi": "^1.2.3",
    "astro": "^6.4.7",
    "astro-icon": "^1.1.5",
    "budoux": "^0.8.4",
    "microcms-js-sdk": "^3.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/pngjs": "^6.0.5",
    "gray-matter": "^4.0.3",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "wrangler": "^4.103.0"
  }
}
